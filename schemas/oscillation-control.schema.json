{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SamuraiWriter7/yin-yang-oscillation-control-protocol-v0.1/schemas/oscillation-control.schema.json",
  "title": "Yin-Yang Oscillation Control Protocol Schema",
  "description": "Schema for the Yin-Yang Oscillation Control Protocol specification and example configuration documents.",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/protocolSpecification"
    },
    {
      "$ref": "#/$defs/exampleDocument"
    }
  ],
  "$defs": {
    "normalizedScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedRange": {
      "type": "object",
      "required": [
        "minimum",
        "maximum"
      ],
      "properties": {
        "minimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "parameterDefinition": {
      "type": "object",
      "required": [
        "description",
        "value_type"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "value_type": {
          "type": "string",
          "enum": [
            "number",
            "integer",
            "string",
            "boolean",
            "object",
            "array"
          ]
        },
        "unit": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "recommended_range": {
          "$ref": "#/$defs/recommendedRange"
        },
        "allowed_values": {
          "$ref": "#/$defs/stringArray"
        },
        "interpretation": {
          "type": "object",
          "properties": {
            "low_value": {
              "type": "string"
            },
            "high_value": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/parameterField"
          }
        },
        "control_use": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "parameterField": {
      "type": "object",
      "required": [
        "value_type"
      ],
      "properties": {
        "value_type": {
          "type": "string",
          "enum": [
            "number",
            "integer",
            "string",
            "boolean",
            "object",
            "array"
          ]
        },
        "unit": {
          "type": "string"
        },
        "recommended_range": {
          "$ref": "#/$defs/recommendedRange"
        },
        "allowed_values": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "convergenceWindowValues": {
      "type": "object",
      "required": [
        "minimum_stability",
        "maximum_variance",
        "observation_cycles"
      ],
      "properties": {
        "minimum_stability": {
          "$ref": "#/$defs/normalizedScore"
        },
        "maximum_variance": {
          "$ref": "#/$defs/normalizedScore"
        },
        "observation_cycles": {
          "$ref": "#/$defs/positiveInteger"
        }
      },
      "additionalProperties": false
    },
    "adaptiveConvergenceValues": {
      "type": "object",
      "required": [
        "enabled",
        "adaptation_mode",
        "adjustment_strength"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "adaptation_mode": {
          "type": "string",
          "enum": [
            "none",
            "context_sensitive",
            "stability_sensitive",
            "phase_sensitive",
            "hybrid"
          ]
        },
        "adjustment_strength": {
          "$ref": "#/$defs/normalizedScore"
        }
      },
      "additionalProperties": false
    },
    "controlParameterValues": {
      "type": "object",
      "properties": {
        "oscillation_period": {
          "$ref": "#/$defs/positiveInteger"
        },
        "amplitude_threshold": {
          "$ref": "#/$defs/normalizedScore"
        },
        "rebalance_interval": {
          "$ref": "#/$defs/positiveInteger"
        },
        "overcorrection_limit": {
          "$ref": "#/$defs/normalizedScore"
        },
        "phase_stability_score": {
          "$ref": "#/$defs/normalizedScore"
        },
        "oscillation_decay": {
          "type": "string",
          "enum": [
            "decaying",
            "persistent",
            "expanding",
            "unknown"
          ]
        },
        "convergence_window": {
          "$ref": "#/$defs/convergenceWindowValues"
        },
        "adaptive_convergence": {
          "$ref": "#/$defs/adaptiveConvergenceValues"
        }
      },
      "additionalProperties": true
    },
    "controlAction": {
      "type": "object",
      "required": [
        "description"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "trigger_conditions": {
          "$ref": "#/$defs/stringArray"
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "profileDefinition": {
      "type": "object",
      "required": [
        "description",
        "parameters"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "parameters": {
          "$ref": "#/$defs/controlParameterValues"
        }
      },
      "additionalProperties": true
    },
    "evaluationStep": {
      "type": "object",
      "required": [
        "step",
        "name",
        "description"
      ],
      "properties": {
        "step": {
          "$ref": "#/$defs/positiveInteger"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolSpecification": {
      "type": "object",
      "required": [
        "spec",
        "metadata",
        "parent_protocol",
        "purpose",
        "design_principles",
        "control_model",
        "core_parameters",
        "control_actions",
        "evaluation_flow",
        "default_profiles",
        "compatibility",
        "claim_boundaries",
        "validation_notes",
        "release_notes"
      ],
      "properties": {
        "spec": {
          "type": "object",
          "required": [
            "id",
            "name",
            "version",
            "status",
            "layer",
            "schema_version",
            "description"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "candidate",
                "stable",
                "deprecated"
              ]
            },
            "layer": {
              "type": "string"
            },
            "schema_version": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "required": [
            "repository",
            "license",
            "specification_type",
            "intended_use",
            "maturity_level"
          ],
          "properties": {
            "repository": {
              "type": "string"
            },
            "license": {
              "type": "string"
            },
            "specification_type": {
              "type": "string"
            },
            "intended_use": {
              "$ref": "#/$defs/stringArray"
            },
            "maturity_level": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "parent_protocol": {
          "type": "object",
          "required": [
            "id",
            "relationship",
            "dependency_type",
            "description"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "relationship": {
              "type": "string"
            },
            "dependency_type": {
              "type": "string"
            },
            "description": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "purpose": {
          "type": "object",
          "required": [
            "summary",
            "goals",
            "non_goals"
          ],
          "properties": {
            "summary": {
              "type": "string"
            },
            "goals": {
              "$ref": "#/$defs/stringArray"
            },
            "non_goals": {
              "$ref": "#/$defs/stringArray"
            }
          },
          "additionalProperties": true
        },
        "design_principles": {
          "$ref": "#/$defs/stringArray"
        },
        "control_model": {
          "type": "object",
          "required": [
            "target_layer",
            "target_system_type",
            "control_objectives",
            "input_signals",
            "output_decisions"
          ],
          "properties": {
            "target_layer": {
              "type": "string"
            },
            "target_system_type": {
              "type": "string"
            },
            "control_objectives": {
              "$ref": "#/$defs/stringArray"
            },
            "input_signals": {
              "$ref": "#/$defs/stringArray"
            },
            "output_decisions": {
              "$ref": "#/$defs/stringArray"
            }
          },
          "additionalProperties": true
        },
        "core_parameters": {
          "type": "object",
          "required": [
            "oscillation_period",
            "amplitude_threshold",
            "convergence_window",
            "rebalance_interval",
            "overcorrection_limit"
          ],
          "properties": {
            "oscillation_period": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "amplitude_threshold": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "convergence_window": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "rebalance_interval": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "overcorrection_limit": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "phase_stability_score": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "oscillation_decay": {
              "$ref": "#/$defs/parameterDefinition"
            },
            "adaptive_convergence": {
              "$ref": "#/$defs/parameterDefinition"
            }
          },
          "additionalProperties": true
        },
        "control_actions": {
          "type": "object",
          "required": [
            "continue_without_rebalance",
            "soft_rebalance",
            "hard_rebalance",
            "delay_convergence",
            "enter_observation_window"
          ],
          "properties": {
            "continue_without_rebalance": {
              "$ref": "#/$defs/controlAction"
            },
            "soft_rebalance": {
              "$ref": "#/$defs/controlAction"
            },
            "hard_rebalance": {
              "$ref": "#/$defs/controlAction"
            },
            "delay_convergence": {
              "$ref": "#/$defs/controlAction"
            },
            "enter_observation_window": {
              "$ref": "#/$defs/controlAction"
            }
          },
          "additionalProperties": true
        },
        "evaluation_flow": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evaluationStep"
          },
          "minItems": 1
        },
        "default_profiles": {
          "type": "object",
          "required": [
            "conservative",
            "balanced",
            "responsive"
          ],
          "properties": {
            "conservative": {
              "$ref": "#/$defs/profileDefinition"
            },
            "balanced": {
              "$ref": "#/$defs/profileDefinition"
            },
            "responsive": {
              "$ref": "#/$defs/profileDefinition"
            }
          },
          "additionalProperties": true
        },
        "compatibility": {
          "type": "object",
          "required": [
            "parent_protocol_required",
            "compatible_layers",
            "implementation_dependency",
            "runtime_required"
          ],
          "properties": {
            "parent_protocol_required": {
              "type": "boolean"
            },
            "compatible_layers": {
              "$ref": "#/$defs/stringArray"
            },
            "implementation_dependency": {
              "type": "string"
            },
            "runtime_required": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "claim_boundaries": {
          "type": "object",
          "required": [
            "project_type",
            "claims"
          ],
          "properties": {
            "project_type": {
              "type": "string"
            },
            "claims": {
              "type": "object",
              "required": [
                "allowed",
                "disallowed"
              ],
              "properties": {
                "allowed": {
                  "$ref": "#/$defs/stringArray"
                },
                "disallowed": {
                  "$ref": "#/$defs/stringArray"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "validation_notes": {
          "type": "object",
          "properties": {
            "yaml_parse_required": {
              "type": "boolean"
            },
            "schema_validation_expected": {
              "type": "boolean"
            },
            "examples_should_reference": {
              "$ref": "#/$defs/stringArray"
            },
            "recommended_next_files": {
              "$ref": "#/$defs/stringArray"
            }
          },
          "additionalProperties": true
        },
        "release_notes": {
          "type": "object",
          "required": [
            "version",
            "summary"
          ],
          "properties": {
            "version": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "exampleDocument": {
      "type": "object",
      "required": [
        "example",
        "parameters"
      ],
      "properties": {
        "example": {
          "type": "object",
          "required": [
            "id",
            "name",
            "description"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "scenario": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "parent_protocol": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "relationship": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "input_signals": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "array",
              "object",
              "null"
            ]
          }
        },
        "parameters": {
          "$ref": "#/$defs/controlParameterValues"
        },
        "expected_control_behavior": {
          "type": "object",
          "properties": {
            "selected_action": {
              "type": "string",
              "enum": [
                "continue_without_rebalance",
                "soft_rebalance",
                "hard_rebalance",
                "delay_convergence",
                "reduce_correction_intensity",
                "enter_observation_window"
              ]
            },
            "reason": {
              "type": "string"
            },
            "notes": {
              "$ref": "#/$defs/stringArray"
            }
          },
          "additionalProperties": true
        },
        "claim_boundaries": {
          "type": "object",
          "properties": {
            "allowed": {
              "$ref": "#/$defs/stringArray"
            },
            "disallowed": {
              "$ref": "#/$defs/stringArray"
            }
          },
          "additionalProperties": true
        },
        "notes": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    }
  }
}

